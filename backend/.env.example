# ============================================================================
# backend/.env.example
# Copia este archivo a backend/.env y completa los valores.
#
# Produccion usa Postgres + Redis. SQLite queda solo para desarrollo local o
# pruebas cuando DATABASE_URL no esta definido.
#
# Importante:
# - No subas backend/.env a git.
# - No pongas comentarios al final de una linea VAR=valor; docker env_file puede
#   interpretar el comentario como parte del valor.
# ============================================================================

# ---------- Entorno ----------
# Activa modo seguro: sin usuarios demo, sin bypass local de login, y el
# arranque FALLA si DATABASE_URL no es Postgres o falta REDIS_URL (fail-fast).
# SQLite solo existe como fallback de desarrollo/tests, nunca en produccion.
APP_ENV=production

# ---------- Datos ----------
POSTGRES_DB=cauce
POSTGRES_USER=cauce
POSTGRES_PASSWORD=CAMBIA_ESTE_PASSWORD
DATABASE_URL=postgresql://cauce:CAMBIA_ESTE_PASSWORD@postgres:5432/cauce
REDIS_URL=redis://redis:6379/0

# ---------- Tenants ----------
# En produccion se usa database. Si queda vacio, Postgres tambien activa DB automaticamente.
TENANTS_SOURCE=database
TENANTS_BOOTSTRAP_OVERWRITE=false

# ---------- LLM / IA ----------
# DeepSeek se usa por defecto porque tenants.json lo referencia por env.
# Se pueden agregar OpenAI, Anthropic u otros via adapters por tenant.
DEEPSEEK_API_KEY=

# ---------- API Brasper (tasas/comisiones/cupones en vivo) ----------
# Las tasas en vivo (GET publicos de apibras.finzeler.com) funcionan SIN secreto.
# BRASPER_IA_SHARED_SECRET solo hace falta para el camino de ESCRITURA (registrar
# la operacion/lead en Brasper), gated por quote.api.write_enabled. Dejalo vacio
# hasta que Brasper entregue el secreto de integracion.
BRASPER_IA_SHARED_SECRET=
# Overrides opcionales del conector (por defecto https://apibras.finzeler.com / 180s).
# BRASPER_API_BASE_URL=https://apibras.finzeler.com
# BRASPER_API_TTL=180

# ---------- Panel: admin de produccion ----------
# Genera el token con:
# cd backend && ../.venv/bin/python manage.py create-admin --email tu@correo.com --name "Tu Nombre"
PANEL_ADMIN_EMAIL=
PANEL_ADMIN_TOKEN=
PANEL_ADMIN_NAME=Administrador

# Codigo temporal de login del panel.
PANEL_LOGIN_CODE=

# Solo desarrollo. Nunca true en produccion.
SEED_DEMO_USERS=false

# ---------- CORS ----------
# En produccion usa tu dominio real, por ejemplo:
# CORS_ALLOW_ORIGINS=https://panel.tu-dominio.com
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# ---------- Rate limiting ----------
# Overrides opcionales por minuto y por IP.
RATE_LIMIT_LOGIN=10
RATE_LIMIT_CHAT=60
RATE_LIMIT_WHATSAPP_WEBHOOK=240
RATE_LIMIT_TELEGRAM_WEBHOOK=240

# Agrupa rafagas de mensajes por tenant/canal/usuario antes de responder.
# Requiere Redis y worker activo. 0 = respuesta inmediata.
CHANNEL_DEBOUNCE_SECONDS=0

# Worker/backups. 0 = desactivado; en produccion puede ser 86400 para diario.
AUTO_BACKUP_INTERVAL_SECONDS=0

# Alertas internas. 0 = desactivado.
COST_ALERT_USD=0

# ---------- WhatsApp Cloud API ----------
# Instructivo completo (Meta oficial): backend/WHATSAPP_SETUP.md
# WHATSAPP_VERIFY_TOKEN: cadena propia; va aqui y en Meta (WhatsApp > Configuration).
#   Generar: openssl rand -hex 16
# META_APP_SECRET: App secret (Meta > Settings > Basic).
# WHATSAPP_REQUIRE_SIGNATURE=true rechaza webhooks sin firma valida.
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=
WHATSAPP_REQUIRE_SIGNATURE=true

# Credenciales por cliente. Los nombres los define backend/config/tenants.json.
# WA_PHONE_NUMBER_ID_*: "Phone number ID" (WhatsApp > API Setup).
# wp_key / WA_TOKEN_*: token PERMANENTE del System User de Meta (no el temporal).
WA_PHONE_NUMBER_ID_BRASPER=
wp_key=
WA_PHONE_NUMBER_ID_CLINICA=
WA_TOKEN_CLINICA=

# ---------- Telegram Bot API ----------
# TOKEN = el de BotFather. SECRET = cadena aleatoria PROPIA (NO el token); valida
# el header X-Telegram-Bot-Api-Secret-Token. Generar: openssl rand -hex 32
TELEGRAM_TOKEN_BRASPER=
TELEGRAM_SECRET_BRASPER=
TELEGRAM_TOKEN_CLINICA=
TELEGRAM_SECRET_CLINICA=

# ---------- Audio / transcripcion (notas de voz de WhatsApp) ----------
# Transcripcion de audios/notas de voz (WhatsApp + Telegram). Dos backends:
#
# 1) whisper_service (recomendado, self-hosted, sin costo por uso) — faster-whisper.
#    Levantar: backend/whisper_service (ver su README) o `docker compose up whisper`.
#    Esta URL manda sobre el service_url del tenant (dev=localhost, docker=whisper):
WHISPER_SERVICE_URL=http://localhost:8090
#
# 2) openai-compatible (/audio/transcriptions). Se usa si no hay whisper_service.
OPENAI_API_KEY=
AUDIO_TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
AUDIO_TRANSCRIPTION_MODEL=whisper-1
#
# Por tenant: bloque "audio" en tenants.json (provider, service_url, language,
# context/initial_prompt, api_key_env, model). Si no hay backend disponible, el
# audio entrante cae a handoff (un asesor lo revisa): nunca rompe la conversacion.

# ---------- Operacion ----------
# Nivel de log del backend (INFO por defecto).
LOG_LEVEL=INFO
# Solo para tooling/tests del worker: procesa la cola una vez y termina.
# WORKER_ONCE=true

# ---------- Alertas externas y tareas periodicas (worker) ----------
# Webhook entrante Slack/Mattermost-compatible para recibir alertas de la plataforma.
# Vacio = solo alertas internas via /api/ops/alerts.
ALERT_WEBHOOK_URL=
ALERT_COOLDOWN_SECONDS=900
# Intervalo del scheduler del worker en segundos (0 = desactivado). Ej: 3600 = cada hora.
SCHED_INTERVAL_SECONDS=0
# Retencion: borra conversaciones inactivas + usage/auditoria mas viejos que N dias (0 = no purgar).
RETENTION_DAYS=0
